# ─── InnoVint API ───
# These can also be configured via the Settings UI in the app.
# They are stored in ~/.cc-billing-cellar-hands-config.json at runtime.

# ─── Server ───
PORT=3007                          # Backend server port (dev: 3007, prod: 3001)
NODE_ENV=development               # development | production

# ─── Firestore (Production only) ───
USE_FIRESTORE=false                # Set to "true" to use Firestore instead of local JSON file
GOOGLE_APPLICATION_CREDENTIALS=    # Path to Firebase service account JSON (required when USE_FIRESTORE=true)
GOOGLE_CLOUD_PROJECT=cc-billing-cellar-hands  # Firebase/GCP project ID

# ─── Local Config ───
CONFIG_PATH=                       # Override path to local config file (default: ~/.cc-billing-cellar-hands-config.json)

# ─── Firebase (Frontend) ───
# These values are set in frontend/src/firebase.ts and must match your Firebase project:
#   apiKey, authDomain, projectId, storageBucket, messagingSenderId, appId
