{
  "hosting": {
    "public": "backend/public",
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "cc-billing-cellar-hands",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
